# Copy to .env (gitignored) for local docker-compose runs.
# In Coolify, set these as Environment Variables on the Application — DO NOT
# commit real values. .NET Core's configuration binder reads "Foo__Bar" env
# vars as the JSON path "Foo:Bar".

# ----- Database -----
# Use a managed SQL Server instance. The same connection works for both keys
# unless you have a separate "PracticeCentral" cluster.
DB_DEFAULT_CONNECTION="Data Source=sqlserver.example.com;Initial Catalog=PI2;User id=appuser;Password=CHANGE_ME;Trusted_Connection=False;MultipleActiveResultSets=true;Encrypt=true;TrustServerCertificate=false"
DB_PRACTICE_CENTRAL_CONNECTION="Data Source=sqlserver.example.com;Initial Catalog=PracticeCentral;User id=appuser;Password=CHANGE_ME;Trusted_Connection=False;MultipleActiveResultSets=true;Encrypt=true;TrustServerCertificate=false"

# ----- JWT -----
# Currently the SecurityService uses a hardcoded HMAC secret in HostService/Startup.cs:53.
# Move it behind Configuration["Jwt:Secret"] then bind from this env var.
JWT_SECRET="CHANGE_ME_min_32_chars_random_secret_here"
JWT_ISSUER="https://api.your-domain.example"
JWT_AUDIENCE="PRACTICE_INSIGHT"

# ----- UI / CORS -----
# CORS in every Startup.cs currently uses AllowAnyOrigin(). Tighten to this
# value when you fix that.
UI_URL="https://app.your-domain.example/"

# ----- AWS DynamoDB (HistoryPaymentRepository) -----
# IMPORTANT: ChargePaymentService/.../HistoryPaymentRepository.cs:32 contains a
# hardcoded AWS access key. Rotate that key and replace the constructor with
# DI-injected IConfiguration values BEFORE deploying anywhere internet-facing.
AWS_ACCESS_KEY_ID="CHANGE_ME"
AWS_SECRET_ACCESS_KEY="CHANGE_ME"
AWS_REGION="us-east-1"

# ----- Misc -----
SITE_LOCALE="en-GB"
USE_SWAGGER="false"      # HostService gates Swagger on this; never true in prod
